/* [project]/app/globals.css [app-client] (css) */
:root {
  --bg: #f5efe4;
  --bg-alt: #fbf7f0;
  --surface: #fff;
  --surface-strong: #0d141c;
  --surface-soft: #e9edf2;
  --text: #101b26;
  --text-soft: #62707b;
  --line: #d7d8de;
  --accent: #d59a36;
  --accent-strong: #ba7f17;
  --teal: #1c7c72;
  --danger: #b74d32;
  --radius: 8px;
  --shadow: 0 20px 60px #0d141c1f;
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  font-family: var(--font-body), ui-sans-serif, sans-serif;
  color: var(--text);
  background: radial-gradient(circle at 0 0, #d59a361f, #0000 26%), radial-gradient(circle at 100% 0, #1c7c7214, #0000 20%), linear-gradient(#f4ede1 0%, #f7f1e7 54%, #fbf7f0 100%);
  margin: 0;
  overflow-x: hidden;
}

a {
  color: inherit;
  text-decoration: none;
}

img {
  max-width: 100%;
  display: block;
}

button, input, select {
  font: inherit;
}

main {
  min-height: 60vh;
}

.shell {
  width: min(1200px, 100% - 32px);
  margin: 0 auto;
}

.site-header .shell {
  width: min(1320px, 100% - 40px);
}

.eyebrow {
  text-transform: uppercase;
  color: var(--accent);
  margin: 0 0 12px;
  font-size: .78rem;
  font-weight: 700;
}

.section {
  padding: 72px 0;
}

.section--tight {
  padding: 28px 0;
}

.section--light {
  background: linear-gradient(180deg, #ffffff70, #fff3),
    var(--bg-alt);
}

.section-header {
  justify-content: space-between;
  align-items: end;
  gap: 24px;
  margin-bottom: 28px;
  display: flex;
}

.section-header h2, .page-hero__content h1, .detail-hero__copy h1, .hero__copy h1, .organizer-hero__content h1 {
  font-family: var(--font-display), serif;
  margin: 0;
  font-size: clamp(2.2rem, 4vw, 4.4rem);
  font-weight: 700;
  line-height: 1.02;
}

.section-header h2 {
  font-size: clamp(1.7rem, 2.6vw, 2.6rem);
}

.section-copy, .page-hero__content p, .hero__lede, .hero__copy p, .content-card__summary, .footer-copy {
  color: var(--text-soft);
  line-height: 1.65;
}

.button {
  border-radius: var(--radius);
  background: var(--accent);
  color: #fff;
  border: 1px solid #0000;
  justify-content: center;
  align-items: center;
  min-height: 48px;
  padding: 0 18px;
  font-weight: 700;
  transition: transform .24s, background .24s, border-color .24s, box-shadow .24s, color .24s;
  display: inline-flex;
}

.button:hover {
  background: var(--accent-strong);
  transform: translateY(-1px);
  box-shadow: 0 18px 36px #ba7f1738;
}

.button--ghost {
  color: var(--text);
  border-color: var(--line);
  background: none;
}

.button--ghost:hover {
  box-shadow: none;
  background: #fff;
}

.button--ghost-on-dark {
  color: #fff;
  background: #ffffff05;
  border-color: #ffffff42;
}

.button--ghost-on-dark:hover {
  box-shadow: none;
  background: #ffffff0f;
}

.button--ghost-light {
  color: #fff;
  background: none;
  border-color: #ffffff59;
}

.button--ghost-light:hover {
  box-shadow: none;
  background: #ffffff14;
}

.button--small {
  min-height: 40px;
  padding: 0 14px;
  font-size: .92rem;
}

.button--full {
  width: 100%;
}

.topbar {
  max-height: 52px;
  color: var(--text);
  background: #10161d;
  padding-top: 6px;
  transition: max-height .34s, opacity .24s, padding .24s;
  overflow: hidden;
}

.topbar__inner, .topbar__meta {
  justify-content: space-between;
  align-items: center;
  gap: 16px;
  display: flex;
}

.topbar__inner {
  background: #fff;
  border: 1px solid #0d141c14;
  border-radius: 999px;
  min-height: 34px;
  padding: 0 16px;
  box-shadow: 0 16px 34px #04090e38;
}

.topbar__contacts {
  align-items: center;
  gap: 18px;
  display: flex;
}

.topbar p, .topbar span {
  margin: 0;
  font-size: .84rem;
  font-weight: 700;
}

.topbar__contacts p {
  color: var(--text);
}

.topbar__meta a, .topbar__meta span, .topbar__contacts span {
  color: #3e4c58;
  font-size: .82rem;
  font-weight: 700;
  transition: color .2s;
}

.topbar__meta a:hover {
  color: var(--accent-strong);
}

.nav-shell {
  background: #0a0f14e6;
  border-bottom: 1px solid #ffffff14;
  transition: background .28s, border-color .28s, box-shadow .28s;
}

.nav {
  align-items: center;
  gap: 22px;
  padding: 18px 0;
  transition: padding .24s, gap .24s;
  display: flex;
}

.site-header {
  z-index: 30;
  -webkit-backdrop-filter: blur(16px);
  backdrop-filter: blur(16px);
  position: sticky;
  top: 0;
}

.site-header.is-scrolled .topbar {
  opacity: 0;
  max-height: 0;
  padding-top: 0;
}

.site-header.is-scrolled .nav-shell, .site-header.is-menu-open .nav-shell {
  background: #0a0f14fa;
  box-shadow: 0 20px 48px #04090e4d;
}

.site-header.is-scrolled .nav {
  padding: 14px 0;
}

.brand {
  color: #fff;
  flex-shrink: 0;
  align-items: center;
  gap: 12px;
  display: flex;
}

.brand__copy {
  gap: 2px;
  min-width: 0;
  display: grid;
}

.brand strong {
  letter-spacing: 0;
  font-size: 1.18rem;
  display: block;
}

.brand small {
  color: #ffffffa6;
  font-size: .78rem;
  font-weight: 700;
  display: block;
}

.brand__mark {
  aspect-ratio: 1;
  border-radius: var(--radius);
  background: var(--accent);
  color: #fff;
  justify-content: center;
  align-items: center;
  width: 40px;
  font-weight: 800;
  transition: transform .24s, box-shadow .24s;
  display: inline-flex;
  box-shadow: 0 14px 28px #d59a362e;
}

.site-header.is-scrolled .brand__mark {
  transform: scale(.96);
}

.nav__panel {
  flex: 1;
  justify-content: space-between;
  align-items: center;
  gap: 18px;
  min-width: 0;
  display: flex;
}

.nav__links, .nav__actions {
  align-items: center;
  gap: 14px;
  display: flex;
}

.nav__links {
  flex-wrap: nowrap;
  min-width: 0;
}

.menu-toggle {
  border-radius: var(--radius);
  background: #ffffff05;
  border: 1px solid #ffffff29;
  width: 48px;
  height: 48px;
  padding: 12px 14px;
  display: none;
}

.menu-toggle__line {
  background: #fff;
  border-radius: 999px;
  width: 100%;
  height: 2px;
  transition: all .2s;
  display: block;
}

.menu-toggle__line + .menu-toggle__line {
  margin-top: 0;
}

.menu-toggle__label {
  color: #fff;
  font-size: .94rem;
  font-weight: 700;
  line-height: 1;
  display: none;
}

.menu-toggle.is-open .menu-toggle__line:first-child {
  transform: translateY(6px)rotate(45deg);
}

.menu-toggle.is-open .menu-toggle__line:nth-child(2) {
  opacity: 0;
}

.menu-toggle.is-open .menu-toggle__line:nth-child(3) {
  transform: translateY(-6px)rotate(-45deg);
}

.nav__links a {
  color: #ffffffd1;
  padding: 8px 0;
  font-size: .98rem;
  font-weight: 800;
  transition: color .22s, transform .22s;
  position: relative;
}

.nav__actions .button {
  min-height: 44px;
  padding: 0 16px;
  font-size: .94rem;
  font-weight: 800;
}

.nav__links a:after {
  content: "";
  transform-origin: center;
  opacity: 0;
  background: linear-gradient(90deg, #d59a3600, #d59a36, #d59a3600);
  height: 1px;
  transition: transform .24s, opacity .24s;
  position: absolute;
  bottom: -2px;
  left: 0;
  right: 0;
  transform: scaleX(.2);
}

.nav__links a:hover {
  color: #fff;
  transform: translateY(-1px);
}

.nav__links a:hover:after {
  opacity: 1;
  transform: scaleX(1);
}

.nav__mobile-only {
  display: none;
}

.hero, .page-hero, .detail-hero, .organizer-hero {
  color: #fff;
  background: #0d141b;
  position: relative;
  overflow: hidden;
}

.hero {
  min-height: clamp(640px, 82vh, 860px);
}

.page-hero {
  min-height: 340px;
}

.page-hero--compact {
  min-height: 240px;
}

.detail-hero {
  min-height: 500px;
}

.organizer-hero {
  min-height: 420px;
}

.hero__image, .page-hero__image, .detail-hero__image, .organizer-hero__image {
  object-fit: cover;
  filter: brightness(.66) saturate(.82) contrast(1.02);
  width: 100%;
  height: 100%;
  position: absolute;
  inset: 0;
}

.hero__image img {
  object-position: center 28%;
  filter: brightness(.58) saturate(.54) contrast(1.04) sepia(.18) hue-rotate(-10deg);
  animation: 18s ease-in-out infinite alternate hero-drift;
}

.hero:before, .page-hero:before, .detail-hero:before, .organizer-hero:before {
  content: "";
  background: linear-gradient(90deg, #070b10f0 0%, #070b10b3 44%, #070b10cc 100%), linear-gradient(#070b1042, #070b10e6), radial-gradient(circle at 78% 22%, #d59a3638, #0000 22%);
  position: absolute;
  inset: 0;
}

.hero:before {
  background: linear-gradient(92deg, #070b10f7 0%, #070b10e6 32%, #070b10b8 58%, #070b10d1 100%), linear-gradient(#070b1038, #070b10eb), radial-gradient(circle at 18% 34%, #d59a363d, #0000 18%), radial-gradient(circle at 76% 18%, #1c7c722e, #0000 22%);
}

.hero__content, .page-hero__content, .detail-hero__content, .organizer-hero__content {
  z-index: 1;
  position: relative;
}

.hero__content {
  grid-template-columns: minmax(0, 1.2fr) minmax(380px, .88fr);
  align-items: center;
  gap: 40px;
  padding: 128px 0 72px;
  display: grid;
}

.hero__copy {
  max-width: 620px;
}

.hero__copy .eyebrow {
  color: #e0ab4d;
  animation: .42s both fade-up;
}

.hero__copy h1 {
  text-shadow: 0 18px 48px #00000057;
  animation: .48s 40ms both fade-up;
}

.hero__lede {
  color: #ffffffdb;
  max-width: 540px;
  font-size: 1.08rem;
  animation: .5s 80ms both fade-up;
}

.hero__actions {
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 24px;
  animation: .52s .12s both fade-up;
  display: flex;
}

.hero-search {
  border-radius: var(--radius);
  background: radial-gradient(circle at 18% 0, #32e1be38, #0000 26%), radial-gradient(circle at 85% 20%, #d59a3638, #0000 28%), linear-gradient(135deg, #1d47caf0, #54129bf0 58%, #0f161ffa);
  border: 1px solid #ffffff29;
  padding: 28px;
  transition: transform .26s, box-shadow .26s, border-color .26s, background .26s;
  animation: .54s 80ms both fade-in-right;
  position: relative;
  overflow: hidden;
  box-shadow: 0 30px 80px #02071057;
}

.hero-search:before {
  content: "";
  opacity: .34;
  pointer-events: none;
  background: linear-gradient(135deg, #ffffff1f, #0000 38%), repeating-linear-gradient(135deg, #ffffff14 0 1px, #0000 1px 18px);
  position: absolute;
  inset: 0;
}

.hero-search > * {
  z-index: 1;
  position: relative;
}

.hero-search__head {
  gap: 8px;
  margin-bottom: 18px;
  display: grid;
}

.hero-search__head p {
  color: #36f1c9;
  letter-spacing: .08em;
  text-transform: uppercase;
  margin: 0;
  font-size: .82rem;
  font-weight: 900;
}

.hero-search__head h2 {
  color: #fff;
  font-family: var(--font-body), ui-sans-serif, sans-serif;
  text-transform: uppercase;
  margin: 0;
  font-size: clamp(1.25rem, 1.7vw, 1.8rem);
  font-weight: 900;
  line-height: 1.1;
}

.hero-search__tabs {
  flex-wrap: wrap;
  justify-content: flex-start;
  gap: 12px;
  margin: 0 0 22px;
  display: flex;
}

.hero-search__tabs a {
  color: #fffffff2;
  background: #fff3;
  border: 1px solid #ffffff1f;
  border-radius: 999px;
  justify-content: center;
  align-items: center;
  min-height: 44px;
  padding: 0 18px;
  font-size: .92rem;
  font-weight: 900;
  display: inline-flex;
  box-shadow: inset 0 1px #ffffff24;
}

.hero-search__tabs a:hover {
  background: #ffffff47;
  border-color: #ffffff57;
  transform: translateY(-2px);
}

.hero-search__fields {
  border-radius: var(--radius);
  background: #050c187a;
  border: 1px solid #ffffff1f;
  grid-template-columns: minmax(0, 1fr) 156px;
  align-items: end;
  gap: 16px;
  padding: 18px;
  display: grid;
  box-shadow: inset 0 1px #ffffff14;
}

.hero-search__field-stack {
  position: relative;
}

.hero-search__field-stack:first-child {
  grid-column: 1 / -1;
}

.hero-search__fields label, .filters-panel label, .form-grid label {
  color: #ffffffc7;
  gap: 8px;
  font-size: .92rem;
  display: grid;
}

.hero-search__fields label {
  color: #ffffffeb;
  grid-template-columns: auto 1fr;
  align-items: center;
  gap: 8px;
  font-weight: 800;
}

.hero-search__field-icon {
  aspect-ratio: 1;
  color: #36f1c9;
  background: #36f1c924;
  border-radius: 999px;
  justify-content: center;
  align-items: center;
  width: 28px;
  display: inline-flex;
}

.hero-search__field-icon svg {
  fill: none;
  stroke: currentColor;
  stroke-linecap: round;
  stroke-linejoin: round;
  stroke-width: 1.8px;
  width: 16px;
  height: 16px;
}

.hero-search__fields input, .hero-search__fields select, .filters-panel input, .filters-panel select, .form-grid input, .form-grid select {
  border-radius: var(--radius);
  width: 100%;
  min-height: 48px;
  color: inherit;
  background: #ffffff14;
  border: 1px solid #ffffff24;
  padding: 0 14px;
}

.hero-search__fields input, .hero-search__fields select {
  color: #fff;
}

.hero-search__fields select option {
  color: var(--text);
}

.filters-panel input, .filters-panel select, .form-grid input, .form-grid select {
  background: var(--surface);
  border-color: var(--line);
  color: var(--text);
}

.hero-search__fields input::placeholder {
  color: #ffffff8f;
}

.hero-search__suggestions {
  z-index: 4;
  border-radius: var(--radius);
  background: #0a0f14fa;
  border: 1px solid #ffffff1f;
  gap: 8px;
  padding: 12px;
  display: grid;
  position: absolute;
  top: calc(100% + 8px);
  left: 0;
  right: 0;
  box-shadow: 0 24px 48px #080c103d;
}

.hero-search__hint {
  color: #ffffffb8;
  font-size: .88rem;
}

.hero-search__suggestion {
  border-radius: var(--radius);
  background: #ffffff08;
  gap: 4px;
  padding: 12px;
  display: grid;
}

.hero-search__suggestion:hover {
  background: #d59a3614;
}

.hero-search__suggestion strong {
  color: #fff;
  font-size: .96rem;
}

.hero-search__suggestion span {
  color: #ffffffad;
  font-size: .84rem;
}

.hero-search__trust {
  color: #ffffffdb;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 16px;
  font-size: .86rem;
  display: flex;
}

.hero-search__trust span {
  background: #ffffff14;
  border: 1px solid #ffffff1f;
  border-radius: 999px;
  padding: 8px 10px;
  font-weight: 700;
