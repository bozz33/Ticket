  margin: 0 0 10px;
  font-size: 2rem;
}

.footer-heading {
  margin: 0 0 12px;
}

.footer-list {
  color: #ffffffbf;
  gap: 10px;
  margin: 0;
  padding: 0;
  list-style: none;
  display: grid;
}

.footer-bottom {
  color: #ffffffb8;
  border-top: 1px solid #ffffff14;
  justify-content: space-between;
  align-items: center;
  gap: 18px;
  padding: 18px 0 28px;
  display: flex;
}

.footer-bottom p {
  margin: 0;
}

@media (max-width: 1100px) {
  .topbar__inner, .hero__content, .listing-layout, .detail-layout, .organizer-layout, .checkout-layout, .footer-grid, .about-grid {
    grid-template-columns: 1fr;
  }

  .nav, .nav__panel {
    gap: 16px;
    display: grid;
  }

  .nav__actions {
    flex-wrap: wrap;
    justify-content: flex-start;
  }

  .hero__content {
    padding-top: 100px;
  }

  .hero-search__tabs {
    justify-content: flex-start;
    margin: 0 0 18px;
  }

  .stats-strip--floating {
    margin-top: -46px;
    margin-bottom: -26px;
  }

  .stats-strip--floating + .section {
    padding-top: 96px;
  }

  .hero-search__fields, .stats-strip__grid, .card-grid--three, .organizer-grid, .speaker-grid, .tile-grid, .support-grid, .offer-grid, .people-grid, .two-column-text, .footer-grid, .gallery-strip {
    grid-template-columns: 1fr 1fr;
  }

  .sticky-panel {
    position: static;
  }

  .checkout-head {
    gap: 14px;
    display: grid;
  }

  .stat-tile {
    min-height: 108px;
    padding: 20px;
  }
}

@media (max-width: 760px) {
  .shell {
    width: min(100% - 24px, 1200px);
  }

  .topbar {
    display: none;
  }

  .section-header, .listing-header, .content-card__footer, .footer-bottom, .organizer-hero__identity, .hero-search__fields, .form-grid, .hero-search__tabs, .hero-search__trust, .card-grid--three, .organizer-grid, .speaker-grid, .tile-grid, .support-grid, .offer-grid, .people-grid, .two-column-text, .footer-grid, .stats-strip__grid, .gallery-strip {
    grid-template-columns: 1fr;
    display: grid;
  }

  .footer-bottom__links, .content-card__meta, .detail-hero__facts, .share-links {
    flex-direction: column;
    align-items: flex-start;
  }

  .nav {
    padding: 14px 0;
    display: block;
  }

  .brand {
    gap: 10px;
  }

  .brand strong {
    font-size: 1rem;
  }

  .brand small {
    display: none;
  }

  .menu-toggle {
    justify-content: center;
    align-items: center;
    gap: 0;
    width: 100%;
    min-width: 0;
    margin-top: 14px;
    padding: 0 14px;
    display: inline-flex;
    position: static;
    transform: none;
  }

  .menu-toggle__label {
    font-size: .92rem;
    display: inline;
  }

  .nav__mobile-only {
    display: inline-flex;
  }

  .nav__panel {
    border-top: 1px solid #ffffff14;
    flex-basis: 100%;
    width: 100%;
    margin-top: 2px;
    padding-top: 16px;
    display: none;
  }

  .nav__panel.is-open {
    gap: 12px;
    animation: .24s both fade-up;
    display: grid;
  }

  .nav__links, .nav__actions {
    gap: 12px;
    display: grid;
  }

  .nav__actions .button {
    width: 100%;
  }

  .section {
    padding: 52px 0;
  }

  .page-hero__pills, .speaker-spotlight__footer, .content-card__publisher {
    display: grid;
  }

  .hero {
    min-height: auto;
  }

  .hero__content, .page-hero__content, .detail-hero__content, .organizer-hero__content {
    padding-top: 72px;
  }

  .hero__copy h1 {
    max-width: 9ch;
    font-size: clamp(2rem, 10.6vw, 3rem);
    line-height: .95;
  }

  .hero__copy, .hero__lede, .hero-search {
    max-width: 100%;
  }

  .hero-search {
    padding: 20px;
    overflow: hidden;
  }

  .hero-search__fields {
    padding: 14px;
  }

  .hero-search__tabs a, .hero-search__fields .button {
    width: 100%;
  }

  .stats-strip--floating {
    margin-top: -22px;
    margin-bottom: 0;
  }

  .stats-strip--floating + .section {
    padding-top: 52px;
  }

  .stat-tile {
    min-height: auto;
  }

  .content-card__topline, .content-card__image-meta {
    left: 14px;
    right: 14px;
  }

  .content-card__publisher-action, .speaker-spotlight__footer .button, .speaker-spotlight__footer .publisher-pill {
    width: 100%;
  }

  .page-hero__pills span, .publisher-pill {
    min-width: 0;
  }

  .content-card__footer-links {
    justify-content: flex-start;
  }

  .organizer-hero__identity {
    grid-template-columns: 1fr;
  }
}

@media (prefers-reduced-motion: reduce) {
  html {
    scroll-behavior: auto;
  }

  *, :before, :after {
    transition-duration: .01ms !important;
    animation-duration: .01ms !important;
    animation-iteration-count: 1 !important;
  }
}

