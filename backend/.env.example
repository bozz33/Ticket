APP_NAME=Ticket
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=UTC

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=central
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ticket_central
DB_USERNAME=postgres
DB_PASSWORD=

CENTRAL_DB_DRIVER=pgsql
CENTRAL_DB_HOST=127.0.0.1
CENTRAL_DB_PORT=5432
CENTRAL_DB_DATABASE=ticket_central
CENTRAL_DB_USERNAME=postgres
CENTRAL_DB_PASSWORD=

TENANT_DB_DRIVER=pgsql
TENANT_DB_HOST=127.0.0.1
TENANT_DB_PORT=5432
TENANT_DB_PREFIX=ticket_
TENANT_DB_DATABASE=ticket_tenant_template
TENANT_DB_USERNAME=postgres
TENANT_DB_PASSWORD=
TENANT_DOMAIN_SUFFIX=

PUBLIC_FRONTEND_URL=http://localhost:3000

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
